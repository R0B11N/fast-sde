# Environment variables for maxim-backend
# DO NOT COMMIT ACTUAL SECRETS

# The port the Express server will run on
PORT=3000

# The connection string for the PostgreSQL database (e.g. from Render or Supabase)
DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# The secret used to sign and verify JSON Web Tokens (must be strong)
JWT_SECRET="replace_with_a_secure_random_string_in_production"
