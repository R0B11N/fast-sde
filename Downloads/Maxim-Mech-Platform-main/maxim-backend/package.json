{
    "name": "maxim-backend",
    "version": "1.0.0",
    "description": "Frank Cusimano - Maxim Mechanical Backend",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "start:prod": "pm2 start ecosystem.config.js --env production",
        "typecheck": "tsc --noEmit",
        "db:migrate": "prisma migrate dev",
        "db:generate": "prisma generate",
        "db:studio": "prisma studio",
        "db:push": "prisma db push",
        "ci:build": "npm ci && npm run db:generate && npm run build"
    },
    "dependencies": {
        "@prisma/client": "^5.x",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^7.2.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^1.4.5-lts.1",
        "prisma": "^5.x",
        "uuid": "^9.0.1",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.x",
        "@types/uuid": "^9.0.8",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.4.5"
    }
}